# A07 跨平台换行符与文本编码规范
# 解决 Windows（CRLF）与 macOS/Linux（LF）协作时的换行符冲突

# ===== 文本文件（统一 LF） =====
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.vue text eol=lf
*.java text eol=lf
*.go text eol=lf
*.rs text eol=lf
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.ps1 text eol=lf
*.psm1 text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.env text eol=lf
*.env.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf

# Windows 批处理保留 CRLF（PowerShell 已用 LF）
*.bat text eol=crlf
*.cmd text eol=crlf

# ===== 二进制文件（禁止 diff/merge） =====
