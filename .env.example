# 本地环境变量样例
# 复制为 .env 后填入实际值，.env 文件不要提交到 Git

# ===== LLM（OpenAI 兼容协议）=====
# DeepSeek
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Qwen（示例）
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-turbo

# ===== 数据库（PostgreSQL）=====
# macOS / Linux 默认
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/a07

# Windows（请改成你的密码）
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/a07

# Docker（两平台一致）
# DATABASE_URL=postgresql://a07:a07@localhost:5432/a07

# SQLite 降级（无 PostgreSQL 时使用，文件路径相对项目根）
# DATABASE_URL=sqlite:///./data/a07.db

# ===== 服务 =====
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# ===== 安全 =====
APP_SECRET_KEY=change-me-in-production
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== 数据 =====
# 模型存储路径（相对项目根）
DATA_DIR=./data
MODEL_DIR=./data/models
