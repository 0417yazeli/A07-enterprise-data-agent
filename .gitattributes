*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.webp binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.pdf binary
*.docx binary
*.xlsx binary
*.pptx binary
*.pkl binary
*.joblib binary
*.parquet binary
*.h5 binary
*.onnx binary
*.pt binary
*.pth binary
*.mp4 binary
*.mov binary
*.avi binary
*.mp3 binary
*.wav binary

